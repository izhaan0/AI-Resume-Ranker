# ── App ──────────────────────────────────────────────────────
APP_NAME="ATS Ranker API"
APP_VERSION="1.0.0"
DEBUG=false

# ── CORS (comma-separated origins) ───────────────────────────
# ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── File Uploads ──────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_RESUMES_PER_REQUEST=20
UPLOAD_DIR=uploads

# ── NLP / ML ──────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm

# ── Database ──────────────────────────────────────────────────
# SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///./ats_ranker.db

# PostgreSQL (uncomment and fill in to use):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ats_ranker
